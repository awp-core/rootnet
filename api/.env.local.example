# API Service — Local overrides (not committed to git)
# Copy to .env.local and fill in values.
# These override the auto-generated .env from scripts/deploy.sh.

# ── Database (override if different from deploy.sh defaults) ──
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/awp?sslmode=disable

# ── Redis ──
# REDIS_URL=redis://localhost:6379/0

# ── HTTP server ──
# HTTP_ADDR=:8080

# ── Private keys (NEVER commit these) ──
RELAYER_PRIVATE_KEY=
