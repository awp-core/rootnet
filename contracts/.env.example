# AWP Protocol — Deployment Configuration
# Copy to .env and fill in all values before running scripts/deploy.sh
#
# The deploy script will:
#   1. Build contracts
#   2. Compute initCodeHashes per tier
#   3. Mine vanity salts via scripts/vanity/mine.sh (using patterns below)
#   4. Deploy all 11 contracts via CREATE2
#   5. Verify on block explorer (optional)
#   6. Generate api/.env

# ═══════════════════════════════════════════
#  Chain Configuration
# ═══════════════════════════════════════════

ETH_RPC_URL=                    # Required — chain RPC endpoint (e.g. https://bsc-dataseed.binance.org)
# ETH_RPC_URL=https://bsc-testnet-rpc.publicnode.com  # BSC testnet example

# ═══════════════════════════════════════════
#  Deployer & Wallets
# ═══════════════════════════════════════════

DEPLOYER_PRIVATE_KEY=0x...      # Required — deployer wallet private key
GUARDIAN=0x...                  # Required — emergency pause guardian (EOA or multisig)
LIQUIDITY_POOL=0x...            # Required — LP wallet (receives 10M AWP at deployment)
AIRDROP=0x...                   # Required — airdrop wallet (receives 100M AWP at deployment)

# ═══════════════════════════════════════════
#  DEX V4 Addresses (chain-specific)
# ═══════════════════════════════════════════
# These are the Uniswap V4 / PancakeSwap V4 contract addresses on the target chain.
# BSC Mainnet values shown as example — replace for other chains.

POOL_MANAGER=0xa0FfB9c1CE1Fe56963B0321B32E7A0302114058b       # CLPoolManager
POSITION_MANAGER=0x55f4c8abA71A1e923edC303eb4fEfF14608cC226   # CLPositionManager
PERMIT2=0x31c2F6fcFf4F8759b3Bd5Bf0e1084A055615c768            # Permit2
CL_SWAP_ROUTER=0x1b81D678ffb9C0263b24A97847620C99d213eB14      # CLSwapRouter

# ═══════════════════════════════════════════
#  Vanity Address Rules
# ═══════════════════════════════════════════
# AlphaToken vanity rule: uint64 packed, 8 positions (4 prefix + 4 suffix).
# Per-position: 0-9=digit, 10-15=lowercase a-f, 16-21=uppercase A-F, >=22(0xFF)=wildcard.
# Example: "A1????cafe" = 0x0A01FFFF0C0A0F0E
# Set to 0 to disable vanity validation for Alpha tokens.
VANITY_RULE=0

# ═══════════════════════════════════════════
#  Contract Vanity Address Patterns
# ═══════════════════════════════════════════
# These define the vanity address patterns for each contract.
# deploy.sh reads these and passes them to scripts/vanity/mine.sh via salt.json.
# Patterns use hex nibbles: digits (0-9) and lowercase hex letters (a-f).
# Leave empty for no pattern (random salt used).
#
# Format: VANITY_PREFIX_<NAME>=<hex_prefix>  VANITY_SUFFIX_<NAME>=<hex_suffix>

VANITY_PREFIX_AWP_TOKEN=0000            # AWPToken: address starts with 0x0000...
VANITY_SUFFIX_AWP_TOKEN=00a1            # AWPToken: address ends with ...00a1
VANITY_PREFIX_AWP_REGISTRY=0000         # AWPRegistry: address starts with 0x0000...
VANITY_SUFFIX_AWP_REGISTRY=00b1         # AWPRegistry: address ends with ...00b1
# VANITY_PREFIX_ALPHA_FACTORY=           # AlphaTokenFactory: no pattern
# VANITY_PREFIX_TREASURY=                # Treasury: no pattern
# VANITY_PREFIX_SUBNET_NFT=              # SubnetNFT: no pattern
# VANITY_PREFIX_LP_MANAGER=              # LPManager: no pattern
# VANITY_PREFIX_STAKING_VAULT=           # StakingVault: no pattern
# VANITY_PREFIX_STAKE_NFT=               # StakeNFT: no pattern
# VANITY_PREFIX_DAO=                     # AWPDAO: no pattern
# VANITY_PREFIX_EMISSION_IMPL=           # AWPEmission impl: no pattern
# VANITY_PREFIX_EMISSION_PROXY=          # AWPEmission proxy: no pattern
# VANITY_PREFIX_SUBNET_MANAGER_IMPL=     # SubnetManager impl: no pattern

# ═══════════════════════════════════════════
#  Per-Contract CREATE2 Salts (auto-generated by deploy.sh)
# ═══════════════════════════════════════════
# These are populated by deploy.sh after mining. You can also pre-fill them
# to skip mining (use --skip-mine flag).
#
# SALT_AWP_TOKEN=0x...
# SALT_ALPHA_FACTORY=0x...
# SALT_TREASURY=0x...
# SALT_AWP_REGISTRY=0x...
# SALT_SUBNET_NFT=0x...
# SALT_LP_MANAGER=0x...
# SALT_STAKING_VAULT=0x...
# SALT_EMISSION_IMPL=0x...
# SALT_EMISSION_PROXY=0x...
# SALT_STAKE_NFT=0x...
# SALT_DAO=0x...
# SALT_SUBNET_MANAGER_IMPL=0x...

# ═══════════════════════════════════════════
#  Block Explorer Verification (optional)
# ═══════════════════════════════════════════
# ETHERSCAN_API_KEY=...

# ═══════════════════════════════════════════
#  API Services (optional, written to api/.env by deploy.sh)
# ═══════════════════════════════════════════
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/awp?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# HTTP_ADDR=:8080
# RELAYER_PRIVATE_KEY=0x...
# KEEPER_PRIVATE_KEY=0x...
