# AWP RootNet — Deployment Configuration
# Copy to .env and fill in all values before running scripts/deploy.sh

# ── Chain ──
ETH_RPC_URL=https://bsc-dataseed.binance.org
# ETH_RPC_URL=https://bsc-testnet-rpc.publicnode.com  # testnet

# ── Deployer ──
DEPLOYER_PRIVATE_KEY=0x...

# ── Addresses ──
GUARDIAN=0x...           # Emergency pause guardian (EOA or multisig)

# ── PancakeSwap V4 (BSC Mainnet) ──
POOL_MANAGER=0xa0FfB9c1CE1Fe56963B0321B32E7A0302114058b
POSITION_MANAGER=0x55f4c8abA71A1e923edC303eb4fEfF14608cC226
PERMIT2=0x31c2F6fcFf4F8759b3Bd5Bf0e1084A055615c768

# ── Vanity Address Rule ──
# uint64 packed rule for AlphaTokenFactory. 0 = no validation.
# Per-position: 0-9=digit, 10-15=lowercase a-f, 16-21=uppercase A-F, >=22=wildcard
VANITY_RULE=0

# ── Per-Contract CREATE2 Salts (optional, for vanity contract addresses) ──
# Pre-mine with: cd contracts && forge script script/Predict.s.sol
# SALT_AWP_TOKEN=0x...
# SALT_ALPHA_FACTORY=0x...
# SALT_TREASURY=0x...
# SALT_ROOTNET=0x...
# SALT_SUBNET_NFT=0x...
# SALT_ACCESS_MANAGER=0x...
# SALT_LP_MANAGER=0x...
# SALT_STAKING_VAULT=0x...
# SALT_STAKE_NFT=0x...
# SALT_DAO=0x...

# ── Block Explorer Verification ──
# ETHERSCAN_API_KEY=...

# ── API Services (optional, written to api/.env) ──
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/awp?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# HTTP_ADDR=:8080
# RELAYER_PRIVATE_KEY=0x...
