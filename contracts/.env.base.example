# AWP Protocol — Base Mainnet Deployment Configuration
# Copy to .env and fill in all values before running scripts/deploy.sh
#
# Chain: Base Mainnet (Chain ID: 8453)
# DEX: Uniswap V4
# Explorer: https://basescan.org

# ═══════════════════════════════════════════
#  Chain Configuration
# ═══════════════════════════════════════════

ETH_RPC_URL=https://mainnet.base.org
# ETH_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY    # Alchemy
# ETH_RPC_URL=https://base.quiknode.pro/YOUR_KEY                 # QuickNode

# ═══════════════════════════════════════════
#  Deployer & Wallets
# ═══════════════════════════════════════════

DEPLOYER_PRIVATE_KEY=0x...      # Required — deployer wallet private key
GUARDIAN=0x...                  # Required — emergency pause guardian (EOA or multisig)
LIQUIDITY_POOL=0x...            # Required — LP wallet (receives 10M AWP at deployment)
AIRDROP=0x...                   # Required — airdrop wallet (receives 100M AWP at deployment)

# ═══════════════════════════════════════════
#  Uniswap V4 Addresses (Base Mainnet)
# ═══════════════════════════════════════════
# Source: https://docs.uniswap.org/contracts/v4/deployments

POOL_MANAGER=0x498581ff718922c3f8e6a244956af099b2652b2b
POSITION_MANAGER=0x7c5f5a4bbd8fd63184577525326123b519429bdc
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
CL_SWAP_ROUTER=0x6ff5693b99212da76ad316178a184ab56d299b43
STATE_VIEW=0xa3c0c9b65bad0b08107aa264b0f3db444b867a71

# ═══════════════════════════════════════════
#  Vanity Address Rules
# ═══════════════════════════════════════════

VANITY_RULE=0                   # Alpha token vanity rule (0 = disabled)

# ═══════════════════════════════════════════
#  Contract Vanity Address Patterns
# ═══════════════════════════════════════════

VANITY_PREFIX_AWP_TOKEN=0000
VANITY_SUFFIX_AWP_TOKEN=00a1
VANITY_PREFIX_AWP_REGISTRY=0000
VANITY_SUFFIX_AWP_REGISTRY=00b1

# ═══════════════════════════════════════════
#  Block Explorer Verification
# ═══════════════════════════════════════════
# Get API key from https://basescan.org/apis
# ETHERSCAN_API_KEY=...

# ═══════════════════════════════════════════
#  API Services (optional, written to api/.env by deploy.sh)
# ═══════════════════════════════════════════
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/awp?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# HTTP_ADDR=:8080
# RELAYER_PRIVATE_KEY=0x...
# KEEPER_PRIVATE_KEY=0x...
